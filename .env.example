# ===== Naver 뉴스 검색 API =====
# https://developers.naver.com 에서 애플리케이션 등록 후 발급
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# ===== Discord =====
# 전송할 채널의 웹훅 URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxx/yyyy

# ===== 선별 개수 =====
# 최종으로 디스코드에 전송할 기사 수 (개발자 관련 AI 뉴스 TOP N)
MAX_FINAL_ITEMS=5
# AI(LLM) 선별 단계로 넘길 후보 기사 수
MAX_CANDIDATES_FOR_AI=20

# ===== DB =====
DB_PATH=./news_history.db

# ===== LLM provider 선택 =====
# ollama(로컬 sLLM) | openai | gemini | claude
LLM_PROVIDER=ollama

# --- Ollama (LLM_PROVIDER=ollama 일 때) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b
# 모델 메모리 유지 시간 (0=즉시 해제, -1=무한, "30m"/"24h" 등도 가능)
OLLAMA_KEEP_ALIVE=0

# --- OpenAI (LLM_PROVIDER=openai 일 때) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Google Gemini (LLM_PROVIDER=gemini 일 때) ---
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-2.0-flash

# --- Anthropic Claude (LLM_PROVIDER=claude 일 때) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8
